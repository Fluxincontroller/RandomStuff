-- Paste your script URL here
local SCRIPT_URL = "https://raw.githubusercontent.com/Fluxincontroller/RandomStuff/refs/heads/main/reloadshi"

-- Print when the script initially runs
print("[Teleport Persistence] Script loaded.")

-- Run the main script once
loadstring(game:HttpGet(SCRIPT_URL))()

-- Teleport persistence (exactly as Infinite Yield does, with added prints)
local TeleportCheck = false
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer

-- Detect which queue_on_teleport function exists
local queueFunc = queue_on_teleport or (syn and syn.queue_on_teleport) or (fluxus and fluxus.queue_on_teleport) or queueteleport

if LocalPlayer and LocalPlayer.OnTeleport and queueFunc then
    LocalPlayer.OnTeleport:Connect(function(State)
        if not TeleportCheck then
            TeleportCheck = true
            print("[Teleport Persistence] Teleport detected. Re-queueing script.")
            queueFunc("loadstring(game:HttpGet('" .. SCRIPT_URL .. "'))()")
        end
        if State == Enum.TeleportState.Completed then
            TeleportCheck = false
            print("[Teleport Persistence] Teleport completed.")
        end
    end)
else
    warn("[Teleport Persistence] queue_on_teleport not available. Script will NOT survive teleports.")
end
